#!/usr/bin/env bash
# lc-opencode-watch
# ------------------------------------------------------------------------------
# Watches the current LeetCode topic and refreshes the external Ghostty OpenCode
# window when the topic changes. It never runs inside the OpenCode TTY.
# ------------------------------------------------------------------------------
set -euo pipefail

ROOT="${LC_REPO_ROOT:-$HOME/Codes/dsa-ml-practice}"
WORKDIR="${LC_WORKDIR:-$ROOT/leetcode}"
CURRENT_DIR="$WORKDIR/.current"
SCRIPTS="$ROOT/scripts"
CACHE_DIR="${LC_CACHE_DIR:-$ROOT/.cache}"
STATE_DIR="$CACHE_DIR/opencode"
PID_FILE="$STATE_DIR/watch.pid"
BASE_WORKSPACE="${LC_OPENCODE_BASE_WORKSPACE:-}"
replace=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --replace)
      replace=1
      shift
      ;;
    *)
      printf 'lc-opencode-watch: unknown argument: %s\n' "$1" >&2
      exit 2
      ;;
  esac
done

mkdir -p "$CURRENT_DIR" "$STATE_DIR"

if [ -f "$PID_FILE" ]; then
  old_pid="$(sed -n '1p' "$PID_FILE" 2>/dev/null || true)"
  if [ -n "$old_pid" ] && kill -0 "$old_pid" >/dev/null 2>&1; then
    if [ "$replace" -eq 1 ]; then
      kill "$old_pid" >/dev/null 2>&1 || true
      for _ in $(seq 1 20); do
        kill -0 "$old_pid" >/dev/null 2>&1 || break
        sleep 0.1
      done
    else
      exit 0
    fi
  fi
fi

printf '%s\n' "$$" > "$PID_FILE"
trap 'rm -f "$PID_FILE"' EXIT

current_topic() {
  "$SCRIPTS/lc-opencode" --print-title
}

open_for_current_topic() {
  "$SCRIPTS/lc-opencode-window" --no-focus --base-workspace "$BASE_WORKSPACE" >/dev/null 2>&1 || true
}

last_topic=""
open_for_current_topic
last_topic="$(current_topic)"

while :; do
  if command -v inotifywait >/dev/null 2>&1; then
    inotifywait -q -t 2 -e close_write -e create -e moved_to -e delete "$CURRENT_DIR" >/dev/null 2>&1 || true
  else
    sleep 2
  fi

  next_topic="$(current_topic)"
  if [ "$next_topic" != "$last_topic" ]; then
    open_for_current_topic
    last_topic="$next_topic"
  fi
done
