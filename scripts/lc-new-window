#!/usr/bin/env bash
# lc-new-window
# ------------------------------------------------------------------------------
# Sets up the standard 3-pane layout inside any new tmux window that is
# created inside the leetcode_practice session. Invoked automatically by the
# `after-new-window` tmux hook that `make tmux` registers.
#
# Standard layout (window = any new window name):
#   pane 1  LEFT          : leetcode TUI  (the browser, source of truth)
#   pane 2  TOP-RIGHT     : nvim          (edits the picked .py file)
#   pane 3  BOTTOM-RIGHT  : shell + lc-watch watcher (test/submit output)
#
# Note: panes are 1-indexed because the user's dotfiles set
# `set -g pane-base-index 1`.
#
# All paths are relative to the user's $HOME; no personal identifiers are
# embedded in this script.
# ------------------------------------------------------------------------------
set -euo pipefail

ROOT="${LC_REPO_ROOT:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)}"
WORKDIR="${LC_WORKDIR:-$ROOT/leetcode}"
SCRIPTS="$ROOT/scripts"
SESSION="leetcode_practice"
MIN_COLS=120
MIN_ROWS=35

leetcode_ready() {
  local output

  output="$(NO_COLOR=1 leetcode whoami 2>&1)" || return 1
  printf '%s\n' "$output" | grep -Fq 'Logged in as'
}

start_leetcode() {
  local pane="$1"

  if leetcode_ready; then
    tmux send-keys -t "$pane" 'leetcode' C-m
    return 0
  fi

  tmux send-keys -t "$pane" "cd \"$ROOT\" && \"$SCRIPTS/lc-healthcheck\"; leetcode login" C-m
}

start_watcher() {
  local pane="$1"
  local pane_id window_id lock_dir lock_pid

  pane_id="$(tmux display-message -p -t "$pane" '#{pane_id}')"
  window_id="$(tmux display-message -p -t "$pane" '#{window_id}')"
  lock_dir="$WORKDIR/.current/lc-watch-${window_id}.lock"
  lock_pid="$(cat "$lock_dir/pid" 2>/dev/null || true)"

  if [ -n "$lock_pid" ] && kill -0 "$lock_pid" 2>/dev/null; then
    return 0
  fi

  rm -rf "$lock_dir"
  nohup env TMUX_PANE="$pane_id" "$SCRIPTS/lc-watch" >/dev/null 2>&1 &
}

first_pane() {
  local target="$1" pane

  while read -r pane; do
    [ -n "$pane" ] || continue
    printf '%s\n' "$pane"
    return 0
  done < <(tmux list-panes -t "$target" -F '#{pane_id}' 2>/dev/null)

  return 1
}

split_pane() {
  local window="$1" pane="$2" direction="$3" percent="$4"
  local result

  if result="$(tmux split-window "$direction" -p "$percent" -P -F '#{pane_id}' -t "$pane" -c "$WORKDIR" 2>&1)"; then
    printf '%s\n' "$result"
    return 0
  fi

  prepare_window_size "$window"

  if result="$(tmux split-window "$direction" -p "$percent" -P -F '#{pane_id}' -t "$pane" -c "$WORKDIR" 2>&1)"; then
    printf '%s\n' "$result"
    return 0
  fi

  printf 'lc-new-window: failed to split %s in %s: %s\n' "$pane" "$window" "$result" >&2
  return 1
}

# tmux passes the new window id from the after-new-window hook. Guessing with
# display-message is unsafe for detached new-window calls because it can return
# the previously active window and split it again.
if [ -z "${TMUX:-}" ]; then
  exit 0
fi

tmux set-window-option -t "$SESSION" window-size latest >/dev/null 2>&1 || true

terminal_cols() {
  local cols=""

  if [ -n "${TMUX:-}" ]; then
    cols="$(tmux display-message -p '#{window_width}' 2>/dev/null || true)"
  elif [ -t 1 ] && command -v tput >/dev/null 2>&1; then
    cols="$(tput cols 2>/dev/null || true)"
  fi

  case "$cols" in
    ''|*[!0-9]*) cols="$MIN_COLS" ;;
  esac

  if [ "$cols" -lt "$MIN_COLS" ]; then
    cols="$MIN_COLS"
  fi

  printf '%s\n' "$cols"
}

terminal_rows() {
  local rows=""

  if [ -n "${TMUX:-}" ]; then
    rows="$(tmux display-message -p '#{window_height}' 2>/dev/null || true)"
  elif [ -t 1 ] && command -v tput >/dev/null 2>&1; then
    rows="$(tput lines 2>/dev/null || true)"
  fi

  case "$rows" in
    ''|*[!0-9]*) rows="$MIN_ROWS" ;;
  esac

  if [ "$rows" -lt "$MIN_ROWS" ]; then
    rows="$MIN_ROWS"
  fi

  printf '%s\n' "$rows"
}

session_has_clients() {
  [ -n "$(tmux list-clients -t "$SESSION" 2>/dev/null || true)" ]
}

client_cols() {
  local cols=0 width height

  while read -r width height; do
    case "$width:$height" in
      *[!0-9:]*|:*|*:|*::*) continue ;;
    esac
    [ "$width" -gt "$cols" ] && cols="$width"
  done < <(tmux list-clients -t "$SESSION" -F '#{client_width} #{client_height}' 2>/dev/null)

  [ "$cols" -gt 0 ] || cols="$(terminal_cols)"
  if [ "$cols" -lt "$MIN_COLS" ]; then
    cols="$MIN_COLS"
  fi
  printf '%s\n' "$cols"
}

client_rows() {
  local rows=0 width height

  while read -r width height; do
    case "$width:$height" in
      *[!0-9:]*|:*|*:|*::*) continue ;;
    esac
    [ "$height" -gt "$rows" ] && rows="$height"
  done < <(tmux list-clients -t "$SESSION" -F '#{client_width} #{client_height}' 2>/dev/null)

  if [ "$rows" -gt 1 ]; then
    rows=$((rows - 1))
  else
    rows="$(terminal_rows)"
  fi

  if [ "$rows" -lt "$MIN_ROWS" ]; then
    rows="$MIN_ROWS"
  fi

  printf '%s\n' "$rows"
}

prepare_window_size() {
  local target="$1"

  tmux set-window-option -t "$target" window-size latest >/dev/null 2>&1 || true

  if ! session_has_clients; then
    tmux resize-window -t "$target" -x "$(terminal_cols)" -y "$(terminal_rows)" >/dev/null 2>&1 || true
    tmux set-window-option -t "$target" window-size latest >/dev/null 2>&1 || true
    return 0
  fi

  tmux resize-window -t "$target" -x "$(client_cols)" -y "$(client_rows)" >/dev/null 2>&1 || true
  tmux set-window-option -t "$target" window-size latest >/dev/null 2>&1 || true
}

window_id="${1:-}"
if [ -z "$window_id" ]; then
  window_id="$(tmux display-message -p '#{window_id}')"
fi
target="${SESSION}:${window_id}"
left_pane=""
top_pane=""
bottom_pane=""

if ! tmux display-message -p -t "$target" '#{window_id}' >/dev/null 2>&1; then
  exit 0
fi

if [ "$(tmux list-panes -t "$target" 2>/dev/null | wc -l)" -ne 1 ]; then
  exit 0
fi

prepare_window_size "$target"

# Pane 1 is the new-window's initial pane. Re-purpose it as the TUI pane.
left_pane="$(first_pane "$target")"
start_leetcode "$left_pane"

# Pane 2: top-right nvim.
top_pane="$(split_pane "$target" "$left_pane" -h 55)"
tmux send-keys -t "$top_pane" "\"$SCRIPTS/lc-nvim\"" C-m

# Pane 3: bottom-right shell running the watcher in the background
# (which auto-opens newly picked .py files in pane 2 and writes the
# current id to a sentinel for the C-a T / C-a S keybinds). The watcher
# must run in the background so the shell is free to run test/submit
# commands in the same pane.
bottom_pane="$(split_pane "$target" "$top_pane" -v 25)"
window_width="$(tmux display-message -p -t "$target" '#{window_width}')"
left_width=$(((window_width * 45 + 50) / 100))
tmux resize-pane -t "$left_pane" -x "$left_width"
tmux resize-pane -t "$bottom_pane" -y 25%
start_watcher "$bottom_pane"

# Land the user on the TUI pane so they can browse.
tmux select-pane -t "$left_pane"
