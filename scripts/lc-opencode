#!/usr/bin/env bash
# lc-opencode
# ------------------------------------------------------------------------------
# Runs plain foreground OpenCode for the current LeetCode topic. This intentionally
# does not supervise or background the TUI; OpenCode owns its Ghostty TTY.
# ------------------------------------------------------------------------------
set -euo pipefail

ROOT="${LC_REPO_ROOT:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)}"
WORKDIR="${LC_WORKDIR:-$ROOT/leetcode}"
CURRENT_DIR="$WORKDIR/.current"
CONFIG_FILE="$ROOT/.opencode/config.env"
PROMPT_FILE="$ROOT/.opencode/dsa-prompt.md"
TUI_CONFIG_FILE="$ROOT/.opencode/tui.json"
CACHE_DIR="${LC_CACHE_DIR:-$ROOT/.cache}"
TMP_ROOT="${LC_TMPDIR:-$CACHE_DIR/tmp}"
LOG_DIR="${LC_OPENCODE_LOG_DIR:-$CACHE_DIR/opencode}"

mkdir -p "$CURRENT_DIR" "$TMP_ROOT" "$LOG_DIR"
export TMPDIR="$TMP_ROOT"

if [ -z "${OPENCODE_CONFIG_CONTENT:-}" ]; then
  export OPENCODE_CONFIG_CONTENT='{"mcp":{"alphaxiv":{"enabled":false}}}'
fi

if [ -z "${OPENCODE_TUI_CONFIG:-}" ] && [ -f "$TUI_CONFIG_FILE" ]; then
  export OPENCODE_TUI_CONFIG="$TUI_CONFIG_FILE"
fi

load_config_defaults() {
  local line key value

  [ -f "$CONFIG_FILE" ] || return 0

  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      ''|\#*) continue ;;
    esac

    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      LC_OPENCODE_MODEL|LC_OPENCODE_FALLBACK_MODEL)
        if [ -z "${!key+x}" ]; then
          export "$key=$value"
        fi
        ;;
    esac
  done < "$CONFIG_FILE"
}

read_first_line() {
  local file="$1"

  [ -f "$file" ] || return 1
  sed -n '1p' "$file" | tr -d '\r'
}

sanitize_title() {
  tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//'
}

current_session_title() {
  local raw_title title

  raw_title="$(read_first_line "$CURRENT_DIR/topic-slug" || true)"
  if [ -z "$raw_title" ]; then
    raw_title="$(read_first_line "$CURRENT_DIR/topic-name" || true)"
  fi

  title="$(printf '%s' "$raw_title" | sanitize_title)"
  if [ -z "$title" ]; then
    title="leetcode_practice"
  fi

  printf '%s\n' "$title"
}

model_available() {
  local model="$1"

  opencode models 2>/dev/null | awk '{print $1}' | grep -Fxq "$model"
}

choose_model() {
  local preferred="$1"
  local fallback="$2"

  if model_available "$preferred"; then
    printf '%s\n' "$preferred"
    return 0
  fi

  if [ "$fallback" != "$preferred" ] && model_available "$fallback"; then
    printf '%s\n' "$fallback"
    return 0
  fi

  printf '%s\n' "$preferred"
}

find_session() {
  local title="$1"
  local directory="$2" escaped_title escaped_directory query

  escaped_title="$(printf '%s' "$title" | sed "s/'/''/g")"
  escaped_directory="$(printf '%s' "$directory" | sed "s/'/''/g")"
  query="select id from session where title = '$escaped_title' and directory = '$escaped_directory' order by time_updated desc limit 1;"

  opencode db "$query" --format json 2>/dev/null | \
    node -e '
const fs = require("fs");
let rows = [];
try {
  rows = JSON.parse(fs.readFileSync(0, "utf8"));
} catch {
  process.exit(0);
}
if (rows[0] && rows[0].id) process.stdout.write(rows[0].id);
' || true
}

seed_prompt() {
  local title="$1"

  if [ -f "$PROMPT_FILE" ]; then
    cat "$PROMPT_FILE"
    printf '\n\n'
  fi

  cat <<EOF
Initialize this OpenCode topic session named "$title".
Read AGENTS.md and the repo-local LeetCode DSA teach skill before helping.
Do not solve anything yet. Reply with READY.
EOF
}

seed_session() {
  local title="$1"
  local model="$2"
  local log_file

  log_file="$LOG_DIR/lc-opencode-seed.$$.log"
  if opencode run --dir "$ROOT" --title "$title" --model "$model" --format json "$(seed_prompt "$title")" >"$log_file" 2>&1; then
    rm -f "$log_file"
    return 0
  fi

  printf 'lc-opencode: failed to seed session "%s" with model %s\n' "$title" "$model" >&2
  sed -n '1,80p' "$log_file" >&2 || true
  rm -f "$log_file"
  return 1
}

run_opencode() {
  if [ "${LC_OPENCODE_NO_EXEC:-0}" = "1" ]; then
    opencode "$@"
  else
    exec opencode "$@"
  fi
}

if [ "${1:-}" = "--print-title" ]; then
  current_session_title
  exit 0
fi

if ! command -v opencode >/dev/null 2>&1; then
  echo "lc-opencode: opencode is not installed or not on PATH" >&2
  exit 1
fi

load_config_defaults

: "${LC_OPENCODE_MODEL:=opencode-go/deepseek-v4-flash}"
: "${LC_OPENCODE_FALLBACK_MODEL:=opencode/deepseek-v4-flash-free}"

model="$(choose_model "$LC_OPENCODE_MODEL" "$LC_OPENCODE_FALLBACK_MODEL")"
session_title="$(current_session_title)"
session_id="$(find_session "$session_title" "$ROOT")"

if [ -z "$session_id" ]; then
  if ! seed_session "$session_title" "$model" && [ "$LC_OPENCODE_FALLBACK_MODEL" != "$model" ]; then
    model="$LC_OPENCODE_FALLBACK_MODEL"
    seed_session "$session_title" "$model" || true
  fi
  session_id="$(find_session "$session_title" "$ROOT")"
fi

cd "$ROOT"

if [ -n "$session_id" ]; then
  run_opencode "$ROOT" --model "$model" --session "$session_id"
  exit $?
fi

if [ -f "$PROMPT_FILE" ]; then
  run_opencode "$ROOT" --model "$model" --prompt "$(cat "$PROMPT_FILE")"
  exit $?
fi

run_opencode "$ROOT" --model "$model"
exit $?
