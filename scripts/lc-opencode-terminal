#!/usr/bin/env bash
# lc-opencode-terminal
# ------------------------------------------------------------------------------
# Runs the repo OpenCode launcher from a Ghostty terminal. If OpenCode exits,
# keep the terminal open so failures are visible instead of silently closing.
# ------------------------------------------------------------------------------
set -euo pipefail

ROOT="${LC_REPO_ROOT:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)}"
SCRIPTS="$ROOT/scripts"

set +e
export LC_OPENCODE_NO_EXEC=1
"$SCRIPTS/lc-opencode"
status="$?"
set -e

printf '\nOpenCode exited with status %s. Press Ctrl-D to close.\n' "$status"
exec "${SHELL:-/bin/bash}" -l
