#!/usr/bin/env bash
# lc-healthcheck
# ------------------------------------------------------------------------------
# Fast repo workflow checks for the LeetCode tmux and external OpenCode setup.
# ------------------------------------------------------------------------------
set -euo pipefail

ROOT="${LC_REPO_ROOT:-$HOME/Codes/dsa-ml-practice}"
WORKDIR="${LC_WORKDIR:-$ROOT/leetcode}"

ok=1

check() {
  local label="$1"
  shift

  if "$@" >/dev/null 2>&1; then
    printf 'ok: %s\n' "$label"
  else
    printf 'fail: %s\n' "$label" >&2
    ok=0
  fi
}

check_tmux_layout() {
  local session="dsa-ml-practice"
  local problem_role="leetcode-problems"
  local width height saw_client=0 match_client=0
  local window_width window_height pane_count=0 pane
  local target="" window_id window_name window_role window_size_option

  command -v tmux >/dev/null 2>&1 || return 0
  tmux has-session -t "$session" 2>/dev/null || return 0
  [ -n "$(tmux list-clients -t "$session" 2>/dev/null || true)" ] || return 0

  while read -r window_id window_name window_role; do
    if [ "$window_role" = "$problem_role" ]; then
      target="$session:$window_id"
      break
    fi
  done < <(tmux list-windows -t "$session" -F '#{window_id} #{window_name} #{@dsa-role}' 2>/dev/null)

  if [ -z "$target" ]; then
    target="$session:1"
  fi

  window_size_option="$(tmux show-options -t "$target" window-size 2>/dev/null || true)"
  [ "$window_size_option" != "window-size manual" ] || return 1

  read -r window_width window_height < <(tmux display-message -p -t "$target" '#{window_width} #{window_height}' 2>/dev/null) || return 1

  while read -r pane; do
    [ -n "$pane" ] || continue
    pane_count=$((pane_count + 1))
  done < <(tmux list-panes -t "$target" -F '#{pane_id}' 2>/dev/null)

  case "$window_width:$window_height:$pane_count" in
    *[!0-9:]*|:*|*:|*::*) return 1 ;;
  esac

  [ "$pane_count" -eq 3 ] || return 1

  while read -r width height; do
    case "$width:$height" in
      *[!0-9:]*|:*|*:|*::*) continue ;;
    esac

    saw_client=1
    if [ "$window_width" -eq "$width" ] && { [ "$window_height" -eq "$height" ] || [ "$window_height" -eq $((height - 1)) ]; }; then
      match_client=1
    fi
  done < <(tmux list-clients -t "$session" -F '#{client_width} #{client_height}' 2>/dev/null)

  [ "$saw_client" -eq 1 ] || return 0
  [ "$match_client" -eq 1 ] || return 1
}

check "leetcode command is installed" command -v leetcode
check "opencode command is installed" command -v opencode
check "ghostty command is installed" command -v ghostty
check "nvim command is installed" command -v nvim
check "repo nvim wrapper is executable" test -x "$ROOT/scripts/lc-nvim"
check "repo OpenCode launcher is executable" test -x "$ROOT/scripts/lc-opencode"
check "repo OpenCode terminal wrapper is executable" test -x "$ROOT/scripts/lc-opencode-terminal"
check "repo OpenCode window launcher is executable" test -x "$ROOT/scripts/lc-opencode-window"
check "repo OpenCode topic watcher is executable" test -x "$ROOT/scripts/lc-opencode-watch"

mkdir -p "$WORKDIR" "$ROOT/.cache/tmp"

check "repo-local tmpdir is writable" test -w "$ROOT/.cache/tmp"
check "repo OpenCode TUI config exists" test -f "$ROOT/.opencode/tui.json"
check "repo OpenCode mouse support is enabled" node -e "const cfg=require(process.argv[1]); process.exit(cfg.mouse === true ? 0 : 1)" "$ROOT/.opencode/tui.json"
check "tmux managed layout fills attached client" check_tmux_layout
check "leetcode workspace is configured" leetcode workspace current
check "leetcode credentials are valid" leetcode whoami
check "opencode can read models" opencode models

if opencode mcp list 2>/dev/null | grep -q 'alphaxiv .*needs authentication'; then
  printf 'warn: alphaxiv MCP needs authentication; repo OpenCode launcher disables it for startup\n' >&2
fi

if [ "$ok" -eq 1 ]; then
  exit 0
fi

printf '\nRun this from %s:\n' "$ROOT" >&2
printf '  make config\n' >&2
printf '  make login\n' >&2
exit 1
