#!/usr/bin/env bash
# lc-opencode-pane
# ------------------------------------------------------------------------------
# Supervises the repo-scoped OpenCode tutor window. The OpenCode session title
# follows the current problem's first topic slug, read from
# leetcode/.current/topic-slug. Existing sessions with the same title and repo
# directory are reused.
# ------------------------------------------------------------------------------
set -euo pipefail

ROOT="${LC_REPO_ROOT:-$HOME/Codes/dsa-ml-practice}"
WORKDIR="${LC_WORKDIR:-$ROOT/leetcode}"
CURRENT_DIR="$WORKDIR/.current"
CONFIG_FILE="$ROOT/.opencode/config.env"
PROMPT_FILE="$ROOT/.opencode/dsa-prompt.md"
TUI_CONFIG_FILE="$ROOT/.opencode/tui.json"
CACHE_DIR="${LC_CACHE_DIR:-$ROOT/.cache}"
TMP_ROOT="${LC_TMPDIR:-$CACHE_DIR/tmp}"
LOG_DIR="${LC_OPENCODE_LOG_DIR:-$CACHE_DIR/opencode}"

mkdir -p "$CURRENT_DIR" "$TMP_ROOT" "$LOG_DIR"
export TMPDIR="$TMP_ROOT"

if [ -z "${OPENCODE_CONFIG_CONTENT:-}" ]; then
  export OPENCODE_CONFIG_CONTENT='{"mcp":{"alphaxiv":{"enabled":false}}}'
fi

if [ -z "${OPENCODE_TUI_CONFIG:-}" ] && [ -f "$TUI_CONFIG_FILE" ]; then
  export OPENCODE_TUI_CONFIG="$TUI_CONFIG_FILE"
fi

opencode_pid=""
watcher_pid=""
session_id=""

load_config_defaults() {
  local line key value

  [ -f "$CONFIG_FILE" ] || return 0

  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      ''|\#*) continue ;;
    esac

    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      LC_OPENCODE_MODEL|LC_OPENCODE_FALLBACK_MODEL)
        if [ -z "${!key+x}" ]; then
          export "$key=$value"
        fi
        ;;
    esac
  done < "$CONFIG_FILE"
}

reset_terminal_modes() {
  local junk

  # OpenCode/OpenTUI enables mouse tracking. If it exits under tmux without a
  # clean teardown, mouse events leak into the shell as [[<...M text.
  printf '\033[?1000l\033[?1002l\033[?1003l\033[?1006l\033[?1015l\033[?1004l\033[?2004l\033[?2027l\033[?2031l\033[?25h\033[0m'
  stty sane 2>/dev/null || true
  [ -t 0 ] || return 0
  while IFS= read -r -s -t 0.05 -n 256 junk 2>/dev/null; do
    :
  done
}

read_first_line() {
  local file="$1"

  [ -f "$file" ] || return 1
  sed -n '1p' "$file" | tr -d '\r'
}

sanitize_title() {
  tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//'
}

current_session_title() {
  local raw_title title

  raw_title="$(read_first_line "$CURRENT_DIR/topic-slug" || true)"
  if [ -z "$raw_title" ]; then
    raw_title="$(read_first_line "$CURRENT_DIR/topic-name" || true)"
  fi

  title="$(printf '%s' "$raw_title" | sanitize_title)"
  if [ -z "$title" ]; then
    title="dsa-practice"
  fi

  printf '%s\n' "$title"
}

model_available() {
  local model="$1"

  opencode models 2>/dev/null | awk '{print $1}' | grep -Fxq "$model"
}

choose_model() {
  local preferred="$1"
  local fallback="$2"

  if model_available "$preferred"; then
    printf '%s\n' "$preferred"
    return 0
  fi

  if [ "$fallback" != "$preferred" ] && model_available "$fallback"; then
    printf '%s\n' "$fallback"
    return 0
  fi

  printf '%s\n' "$preferred"
}

find_session() {
  local title="$1"
  local directory="$2" escaped_title escaped_directory query

  escaped_title="$(printf '%s' "$title" | sed "s/'/''/g")"
  escaped_directory="$(printf '%s' "$directory" | sed "s/'/''/g")"
  query="select id from session where title = '$escaped_title' and directory = '$escaped_directory' order by time_updated desc limit 1;"

  opencode db "$query" --format json 2>/dev/null | \
    node -e '
const fs = require("fs");
let rows = [];
try {
  rows = JSON.parse(fs.readFileSync(0, "utf8"));
} catch {
  process.exit(0);
}
if (rows[0] && rows[0].id) process.stdout.write(rows[0].id);
' || true
}

seed_prompt() {
  local title="$1"

  if [ -f "$PROMPT_FILE" ]; then
    cat "$PROMPT_FILE"
    printf '\n\n'
  fi

  cat <<EOF
Initialize this OpenCode topic session named "$title".
Read AGENTS.md and the repo-local DSA teach skill before helping.
Do not solve anything yet. Reply with READY.
EOF
}

seed_session() {
  local title="$1"
  local model="$2"
  local log_file

  log_file="$LOG_DIR/lc-opencode-seed.$$.log"
  if opencode run --dir "$ROOT" --title "$title" --model "$model" --format json "$(seed_prompt "$title")" >"$log_file" 2>&1; then
    rm -f "$log_file"
    return 0
  fi

  printf 'lc-opencode-pane: failed to seed session "%s" with model %s\n' "$title" "$model" >&2
  sed -n '1,80p' "$log_file" >&2 || true
  rm -f "$log_file"
  return 1
}

ensure_session() {
  local title="$1"

  session_id="$(find_session "$title" "$ROOT")"
  if [ -n "$session_id" ]; then
    return 0
  fi

  if ! seed_session "$title" "$model"; then
    if [ "$LC_OPENCODE_FALLBACK_MODEL" != "$model" ]; then
      model="$LC_OPENCODE_FALLBACK_MODEL"
      seed_session "$title" "$model" || true
    fi
  fi

  session_id="$(find_session "$title" "$ROOT")"
}

watch_topic_change() {
  local initial_title="$1" next_title

  while :; do
    next_title="$(current_session_title)"
    if [ "$next_title" != "$initial_title" ]; then
      return 0
    fi

    if command -v inotifywait >/dev/null 2>&1; then
      inotifywait -q -t 2 -e close_write -e create -e moved_to -e delete "$CURRENT_DIR" >/dev/null 2>&1 || true
    else
      sleep 2
    fi
  done
}

stop_child() {
  local pid="$1"

  [ -n "$pid" ] || return 0
  kill "$pid" >/dev/null 2>&1 || return 0
  sleep 1
  kill -TERM "$pid" >/dev/null 2>&1 || true
  wait "$pid" >/dev/null 2>&1 || true
}

cleanup() {
  stop_child "$watcher_pid"
  stop_child "$opencode_pid"
  reset_terminal_modes
}

shutdown() {
  cleanup
  exit 0
}

trap cleanup EXIT
trap shutdown INT TERM

if ! command -v opencode >/dev/null 2>&1; then
  echo "lc-opencode-pane: opencode is not installed or not on PATH" >&2
  exec "${SHELL:-/bin/sh}" -l
fi

load_config_defaults

: "${LC_OPENCODE_MODEL:=opencode-go/deepseek-v4-flash}"
: "${LC_OPENCODE_FALLBACK_MODEL:=opencode/deepseek-v4-flash-free}"

model="$(choose_model "$LC_OPENCODE_MODEL" "$LC_OPENCODE_FALLBACK_MODEL")"

cd "$ROOT"

while :; do
  SESSION_TITLE="$(current_session_title)"
  ensure_session "$SESSION_TITLE"

  reset_terminal_modes
  printf 'lc-opencode-pane: opening topic session "%s"\n' "$SESSION_TITLE" >&2
  if [ -n "$session_id" ]; then
    opencode "$ROOT" --model "$model" --session "$session_id" &
  elif [ -f "$PROMPT_FILE" ]; then
    opencode "$ROOT" --model "$model" --prompt "$(cat "$PROMPT_FILE")" &
  else
    opencode "$ROOT" --model "$model" &
  fi
  opencode_pid="$!"

  watch_topic_change "$SESSION_TITLE" &
  watcher_pid="$!"

  finished_pid=""
  set +e
  wait -n -p finished_pid "$opencode_pid" "$watcher_pid"
  status="$?"
  set -e

  if [ "$finished_pid" = "$watcher_pid" ]; then
    printf 'lc-opencode-pane: topic changed; reopening OpenCode\n' >&2
    stop_child "$opencode_pid"
    reset_terminal_modes
    opencode_pid=""
    watcher_pid=""
    continue
  fi

  stop_child "$watcher_pid"
  reset_terminal_modes
  opencode_pid=""
  watcher_pid=""

  printf '\r\033[2K' >&2
  printf 'lc-opencode-pane: OpenCode exited with status %s; leaving pane at shell\n' "$status" >&2
  exit "$status"
done
