#!/usr/bin/env bash
# lc-watch
# ------------------------------------------------------------------------------
# inotifywait-based bridge between the leetcode TUI's `p` (pick) action and
# the nvim pane in the same window. Runs in the bottom-right pane.
#
# What it does:
#   1. Watches $WORKDIR for new or moved-in .py files.
#   2. When one appears, sends `:edit <path>` to the nvim pane in the
#      same window so the
#      picked solution auto-opens.
#   3. Writes the problem id and path to sentinels under $WORKDIR/.current/
#      so the test/submit keybinds (C-a T, C-a S) target the active file.
#
# This script does NOT need to be invoked manually. The `make tmux` target
# starts it in the bottom-right pane of each workflow window.
# ------------------------------------------------------------------------------
set -euo pipefail

ROOT="${LC_REPO_ROOT:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)}"
WORKDIR="${LC_WORKDIR:-$ROOT/leetcode}"
ID_SENTINEL="$WORKDIR/.current/id"
PATH_SENTINEL="$WORKDIR/.current/path"

mkdir -p "$(dirname "$ID_SENTINEL")"

# $TMUX_PANE is the pane that ran this script (the bottom-right shell).
my_pane="${TMUX_PANE:-}"
if [ -z "$my_pane" ]; then
  echo "lc-watch: not running inside a tmux pane" >&2
  exit 1
fi

window_id="$(tmux display-message -p -t "$my_pane" '#{window_id}')"
LOCK_DIR="$WORKDIR/.current/lc-watch-${window_id}.lock"

nvim_pane() {
  local pane index=0

  while read -r pane; do
    [ -n "$pane" ] || continue
    index=$((index + 1))
    if [ "$index" -eq 2 ]; then
      printf '%s\n' "$pane"
      return 0
    fi
  done < <(tmux list-panes -t "$window_id" -F '#{pane_id}' 2>/dev/null)

  return 1
}

if ! mkdir "$LOCK_DIR" 2>/dev/null; then
  old_pid="$(cat "$LOCK_DIR/pid" 2>/dev/null || true)"
  if [ -n "$old_pid" ] && kill -0 "$old_pid" 2>/dev/null; then
    exit 0
  fi

  rm -rf "$LOCK_DIR"
  mkdir "$LOCK_DIR"
fi

printf '%s\n' "$$" > "$LOCK_DIR/pid"
trap 'rm -rf "$LOCK_DIR"' EXIT

# Extract the leading problem id from "<id>.<slug>.<ext>" e.g. 1.two-sum.py
extract_id() {
  basename "$1" | sed -E 's/^([0-9]+)\..*/\1/'
}

is_primary_solution() {
  basename "$1" | grep -Eq '^[0-9]+\.[^.]+\.py$'
}

escape_vim_path() {
  printf '%s' "$1" | sed -e 's/[\\ %#|]/\\&/g'
}

ensure_python_body() {
  python3 - "$1" <<'PY'
from pathlib import Path
import re
import sys

path = Path(sys.argv[1])
lines = path.read_text().splitlines()
i = len(lines) - 1
while i >= 0 and not lines[i].strip():
    i -= 1
if i < 0 or not lines[i].rstrip().endswith(":"):
    raise SystemExit

indent = re.match(r"^(\s*)", lines[i]).group(1) + "    "
path.write_text("\n".join(lines[: i + 1] + [f"{indent}pass"]) + "\n")
PY
}

tmux_target_exists() {
  [ -n "$(tmux display-message -p -t "$1" '#{pane_id}' 2>/dev/null || true)" ]
}

nvim_pane_id="$(nvim_pane || true)"

while tmux_target_exists "$my_pane" && [ -n "$nvim_pane_id" ] && tmux_target_exists "$nvim_pane_id"; do
  events="$(inotifywait -q -r "$WORKDIR" -e create -e moved_to --format '%w%f' -t 2 2>/dev/null || true)"
  [ -n "$events" ] || continue

  while read -r path; do
    case "$path" in
      *.py)
        is_primary_solution "$path" || continue
        ensure_python_body "$path"
        id="$(extract_id "$path")"
        if [ -n "$id" ]; then
          printf '%s\n' "$id" > "$ID_SENTINEL"
        fi
        printf '%s\n' "$path" > "$PATH_SENTINEL"
        tmux send-keys -t "$nvim_pane_id" ":edit $(escape_vim_path "$path")" C-m
        ;;
    esac
  done <<< "$events"
done
